# Скопіюйте цей файл у ".env" і задайте хеші паролів перед збіркою (npm run build).
# У зібраний JS потрапляє лише SHA-256-хеш — відкритий текст пароля тримайте поза git.
# Отримати хеш:
#   node -e "console.log(require('crypto').createHash('sha256').update('ВАШ_ПАРОЛЬ').digest('hex'))"

# Пароль входу в касу
VITE_APP_PASSWORD_SHA256=

# Пароль адміністратора (екран «Облік товарів»)
VITE_ADMIN_PASSWORD_SHA256=
